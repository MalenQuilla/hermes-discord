{
  "name": "Daily Finance Brief",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 7 * * 1-5" }]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_WEBHOOK_URL || 'http://hermes:8642' }}/api/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"channel\": \"finance\",\n  \"message\": \"Daily finance brief requested. Provide: (1) major index moves SPY/QQQ/DIA, (2) BTC/ETH prices, (3) notable Polymarket movers, (4) any earnings today.\",\n  \"profile\": \"master\",\n  \"metadata\": { \"source\": \"n8n-cron\", \"workflow\": \"daily-finance-brief\" }\n}"
      },
      "name": "Trigger Hermes Finance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [470, 300]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [{ "node": "Trigger Hermes Finance", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "Asia/Ho_Chi_Minh"
  },
  "active": false,
  "tags": [{ "name": "hermes" }, { "name": "finance" }, { "name": "cron" }]
}
