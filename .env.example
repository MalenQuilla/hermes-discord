# ─── LLM Providers ───────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Tiered model split:
#   MASTER  = small/cheap model — only routes + relays + light inline answers
#   WORKER  = stronger reasoning model — does actual specialist work
#   JUDGE   = tiny model — goal-loop continuation decisions
HERMES_PROVIDER=openrouter
HERMES_MASTER_MODEL=google/gemini-flash-2.0
HERMES_WORKER_MODEL=anthropic/claude-sonnet-4-6
HERMES_DELEGATION_MODEL=google/gemini-flash-2.0
HERMES_JUDGE_MODEL=google/gemini-flash-2.0
# Per-agent overrides (leave blank to inherit HERMES_WORKER_MODEL)
HERMES_FINANCE_MODEL=
HERMES_NEWS_MODEL=
HERMES_BRAIN_MODEL=
HERMES_EMAIL_MODEL=
HERMES_N8N_ENG_MODEL=
HERMES_GH_ENG_MODEL=anthropic/claude-opus-4-7

# ─── Discord Gateway ─────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_MASTER_CHANNEL_ID=
DISCORD_FINANCE_CHANNEL_ID=
DISCORD_NEWS_CHANNEL_ID=
DISCORD_BRAIN_CHANNEL_ID=
DISCORD_EMAIL_CHANNEL_ID=

# ─── n8n ─────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASS=changeme
N8N_API_KEY=
N8N_WEBHOOK_URL=http://hermes:8642
N8N_ENCRYPTION_KEY=changeme-32-char-encryption-key!

# ─── Postgres (for n8n) ──────────────────────────────────────────
POSTGRES_PASS=changeme

# ─── GitHub ──────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo
GITHUB_ISSUE_LABEL=agent-todo

# ─── Obsidian (Local REST API plugin on host) ───────────────────
OBSIDIAN_API_URL=http://host.docker.internal:27124
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_PATH=/Users/tung-dnt/Library/Mobile Documents/iCloud~md~obsidian/Documents/Personal

# ─── Gmail (google-workspace skill OAuth) ───────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=you@gmail.com
EMAIL_DRAFT_ONLY=true

# ─── Financial APIs ──────────────────────────────────────────────
ALPHA_VANTAGE_KEY=
COINGECKO_API_KEY=

# ─── Tenant ──────────────────────────────────────────────────────
HERMES_TENANT=me
